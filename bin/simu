#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../lib/simu'

begin
  Simu::CLI.start(ARGV)
rescue Interrupt
  puts "\nAborted."
  exit(0)
rescue StandardError => e
  if e.class.name == 'TTY::Reader::InputInterrupt'
    puts "\nAborted."
    exit(0)
  else
    raise e
  end
end
